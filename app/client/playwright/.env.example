# Copy this file to .env and fill in your credentials
# cp playwright/.env.example playwright/.env

USERNAME=your@email.com
PASSWORD=your-password

# Override base URL (defaults to https://dev.appsmith.com)
# PLAYWRIGHT_BASE_URL=https://dev.appsmith.com

# Gitea (local git server for Git import tests)
GITEA_BASE_URL=http://localhost:4200
GITEA_API_TOKEN=
GIT_CLONE_URL=git@host.docker.internal:Cypress
